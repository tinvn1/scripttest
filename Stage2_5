-- =========================================================================
-- 🕵️‍♂️ CƠ CHẾ SPY 2.5 INDEPENDENT: CHECK TRẠNG THÁI LÊN CẤP 2 ĐỂ MỞ CỬA MAP
-- =========================================================================
_G.ActivateSpy25 = function(genPart)
    if not genPart then 
        _G.CurrentStage = 1 
        return 
    end
    
    local genModel = genPart:IsA("Model") and genPart or genPart.Parent
    local isLevelUpDetected = false
    local maxWaitTime = 6 -- Thời gian tối đa (giây) chờ thế giới game cập nhật lên cấp 2
    
    print("[🕵️‍♂️ SPY 2.5] Kích hoạt luồng rình máy phát điện lên cấp mở map...")
    
    -- Lắng nghe các biến động nhỏ nhất (Thêm/Bớt linh kiện khi máy biến đổi cấu trúc lên cấp 2)
    local connectionAdd = genModel.DescendantAdded:Connect(function(descendant)
        print("[⚡ SPY DETECTED] Thế giới thay đổi cấu trúc nhỏ! Đã nhận Object mới: " .. descendant.Name)
        isLevelUpDetected = true
    end)
    
    local connectionRemove = genModel.DescendantRemoving:Connect(function(descendant)
        print("[⚡ SPY DETECTED] Thế giới thay đổi cấu trúc nhỏ! Đas mất Object: " .. descendant.Name)
        isLevelUpDetected = true
    end)
    
    -- Luồng đếm ngược thời gian chờ cập nhật thế giới thực tế
    task.spawn(function()
        local startTime = os.clock()
        while (os.clock() - startTime) < maxWaitTime do
            if isLevelUpDetected then break end
            task.wait(0.1)
        end
        
        -- Ngắt kết nối sự kiện lập tức sau khi check xong để tránh rò rỉ bộ nhớ (Lag game)
        connectionAdd:Disconnect()
        connectionRemove:Disconnect()
        
        -- ĐÁNH GIÁ BIẾN SỐ ĐỂ ĐIỀU HƯỚNG HOẶC PHẠT
        if isLevelUpDetected then
            print("[🎯 SPY SUCCESS] Xác nhận máy đã biến đổi lên cấp thành công! Mở khóa Stage 3.")
            _G.CurrentStage = 3  -- Cho phép Stage 3 (Chạy tới trạm điện Power Box) hoạt động
        else
            -- CƠ CHẾ PHẠT: Máy đứng im trơ trơ không chịu lên cấp mở cửa map
            warn("[❌ SPY FAILED] Quá thời gian chờ nhưng máy im lìm, chưa đủ điều kiện lên cấp! PHẠT: Lùi về Stage 1.")
            _G.CurrentStage = 1  -- Phạt ép đi nhặt lại nhiên liệu / Reset hành vi vòng lặp
        end
    end)
end
