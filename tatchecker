-- =========================================================================
-- ⏳ SCRIPT TỰ ĐỘNG ẨN HUB 15 GIÂY RỒI MỞ LẠI
-- =========================================================================

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- Tìm Hub đã tạo từ trước dựa theo đúng tên đặt trong script gốc
local ScreenGui = PlayerGui:FindFirstChild("Gemini_UltimateToggleHub")

if ScreenGui then
    local HubContent = ScreenGui:FindFirstChild("HubContent") or ScreenGui:FindFirstChildWhichIsA("Frame")
    local ToggleButton = ScreenGui:FindFirstChild("TextButton") or ScreenGui:FindFirstChildWhichIsA("TextButton")

    if HubContent then
        -- 1. Tiến hành ẩn Hub ngay lập tức
        HubContent.Visible = false
        
        -- Cập nhật trạng thái nút bấm (nếu có nút bấm) để đồng bộ giao diện
        if ToggleButton then
            ToggleButton.Text = "HIỆN HUB"
            ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            local ButtonStroke = ToggleButton:FindFirstChildWhichIsA("UIStroke")
            if ButtonStroke then
                ButtonStroke.Color = Color3.fromRGB(100, 100, 100)
            end
        end
        print("[⏳ HUB CONTROL] Đã ẩn Hub. Đang đợi 15 giây...")

        -- 2. Chờ đúng 15 giây
        task.wait(15)

        -- 3. Tự động hiển thị lại Hub
        HubContent.Visible = true
        
        -- Cập nhật lại trạng thái nút bấm về ban đầu
        if ToggleButton then
            ToggleButton.Text = "ẨN HUB"
            ToggleButton.TextColor3 = Color3.fromRGB(0, 230, 255)
            local ButtonStroke = ToggleButton:FindFirstChildWhichIsA("UIStroke")
            if ButtonStroke then
                ButtonStroke.Color = Color3.fromRGB(0, 230, 255)
            end
        end
        print("[🚀 HUB CONTROL] Đã hết 15 giây! Hub đã được tự động mở lại.")
    else
        warn("[❌ HUB CONTROL] Không tìm thấy nội dung HubContent bên trong UI!")
    end
else
    warn("[❌ HUB CONTROL] Không tìm thấy Hub nào có tên 'Gemini_UltimateToggleHub' đang hoạt động!")
end
