if not game:IsLoaded() then game.Loaded:Wait() end

print("[⚡ SYSTEM GITHUB] Khởi động Bootloader đồng bộ...");

local function loadStage(url, name)
    local success, content = pcall(function()
        return game:HttpGet(url)
    end)
    
    if success and content then
        local func, err = loadstring(content)
        if func then
            print("[▶️] Đang chạy cấu phần: " .. name)
            return func() 
        else
            warn("Lỗi biên dịch cấu phần: " .. name .. " | " .. tostring(err))
        end
    else
        warn("Không thể tải dữ liệu đường dẫn trực tuyến từ GitHub: " .. name)
    end
    return false
end

-- ĐƯỜNG DẪN RAW LINK ĐÃ ĐƯỢC SỬA LỖI TRÙNG LẶP THƯ MỤC MAIN:
local STAGE1_URL = "https://raw.githubusercontent.com/tinvn1/scripttest/refs/heads/main/Stage1_GetFuel.lua"
local STAGE2_URL = "https://raw.githubusercontent.com/tinvn1/scripttest/refs/heads/main/Stage2_ReturnGen.lua"
local STAGE3_URL = "hhttps://raw.githubusercontent.com/tinvn1/scripttest/refs/heads/main/Stage3_RepairBox.lua"

task.spawn(function()
    while true do
        print("[HỆ THỐNG] KHỞI ĐỘNG CHU KỲ TRẬN ĐẤU MỚI")
        
        local s1_done = loadStage(STAGE1_URL, "Stage 1: Nhặt Fuel")
        if s1_done then
            local s2_done = loadStage(STAGE2_URL, "Stage 2: Về Máy Phát Điện")
            if s2_done then
                local s3_done = loadStage(STAGE3_URL, "Stage 3: Sửa Trạm Điện PowerBox")
                if s3_done then
                    print("[HỆ THỐNG] CHU KỲ HOÀN TẤT XUẤT SẮC KHÔNG LỖI!");
                end
            end
        end
        task.wait(2)
    end
end)
