if not game:IsLoaded() then game.Loaded:Wait() end

print("[⚡ SYSTEM GITHUB] Khởi động Bootloader đồng bộ...");

local function loadStage(url, name)
    local success, content = pcall(function()
        return game:HttpGet(url)
    end)
    
    if success and content then
        local func, err = loadstring(content)
        if func then
            print("[▶️] Đang chạy cấu phần: " .. name)
            return func() 
        else
            warn("Lỗi biên dịch cấu phần: " .. name .. " | " .. tostring(err))
        end
    else
        warn("Không thể tải dữ liệu trực tuyến từ GitHub: " .. name)
    end
    return false
end

local baseUrl = "https://raw.githubusercontent.com/tinvn1/scripttest/refs/heads/main/"

-- Danh sách chạy tuần tự theo mảng:
local stages = {
    "Stage1_GetFuel.lua", 
    "Stage2_ReturnGen.lua", 
    "Stage3_RepairBox.lua", 
    "Stage4_Template.lua" -- Bắt buộc phải có file này ở cuối danh sách
}

task.spawn(function()
    while true do
        local allStagesCleared = true
        
        for _, stageName in ipairs(stages) do
            local currentUrl = baseUrl .. stageName
            local isDone = loadStage(currentUrl, stageName)
            
            -- Nếu một Stage trả về false (ngắt luồng do lệnh treo máy), bẻ gãy vòng lặp for ngay lập tức
            if not isDone then
                allStagesCleared = false
                break
            end
            task.wait(1)
        end
        
        -- Nếu gặp file Stage 4 treo máy (allStagesCleared = false), luồng vòng lặp while sẽ bị chặn đứng không thể quay lại Stage 1
        if not allStagesCleared then
            print("[🏁 SYSTEM] Luồng chính đã bị khóa tại trạm điện. Dừng chu kỳ!")
            break
        end
        
        task.wait(2)
    end
end)
