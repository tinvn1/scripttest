if not game:IsLoaded() then game.Loaded:Wait() end

print("[⚡ SYSTEM GITHUB] Khởi động Bootloader đồng bộ...");

local function loadStage(url, name)
    local success, content = pcall(function()
        return game:HttpGet(url)
    end)
    
    if success and content then
        local func, err = loadstring(content)
        if func then
            print("[▶️] Đang chạy cấu phần: " .. name)
            return func() 
        else
            warn("Lỗi biên dịch cấu phần: " .. name .. " | " .. tostring(err))
        end
    else
        warn("Không thể tải dữ liệu đường dẫn trực tuyến từ GitHub: " .. name)
    end
    return false
end

local baseUrl = "https://raw.githubusercontent.com/tinvn1/scripttest/refs/heads/main/"

-- 🔥 ĐÃ CHỈNH SỬA: Thêm Stage 4 vào danh sách chạy tuần tự
local stages = {
    "Stage1_GetFuel.lua", 
    "Stage2_ReturnGen.lua", 
    "Stage3_RepairBox.lua", 
    "Stage4_Template.lua" -- File trung gian giữ chân nhân vật
}

task.spawn(function()
    while true do
        for _, stageName in ipairs(stages) do
            local currentUrl = baseUrl .. stageName
            -- Tải và chạy tuần tự, file trước hoàn thành (return true) thì file sau mới chạy
            local isDone = loadStage(currentUrl, stageName)
            
            if not isDone then
                -- Nếu cấu phần trả về false (ngắt luồng do lỗi hoặc do lệnh giữ chân), dừng vòng lặp tại đây
                print("[⚠️] Phát hiện luồng dừng hoặc lỗi tại: " .. stageName)
                break
            end
            task.wait(1)
        end
        -- Dừng hẳn 5 giây trước khi check lại hệ thống, tránh spam log game
        task.wait(5)
    end
end)
